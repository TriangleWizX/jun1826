Options -MultiViews
RewriteEngine On
RewriteBase /

# IndexNow key file for Ahrefs verification:
# allow public direct access and bypass all rewrite/canonical chains.
<Files "ch9sdfpu2ajh2rzbs1ed516zrfep9451.txt">
  Require all granted
  ForceType text/plain
  AddDefaultCharset UTF-8
</Files>
RewriteRule ^ch9sdfpu2ajh2rzbs1ed516zrfep9451\.txt$ - [L]

# --- Canonical host / protocol ---
# Collapse www to the canonical HTTPS host before any scheme-only rewrite can add an extra hop.
RewriteCond %{HTTP_HOST} ^www\.senseisandy\.com$ [NC]
RewriteRule ^ https://senseisandy.com%{REQUEST_URI} [L,R=301,NE]

# Force HTTPS + non-www in one hop, including proxied SSL requests.
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC,OR]
RewriteCond %{HTTP_HOST} ^www\.senseisandy\.com$ [NC]
RewriteRule ^ https://senseisandy.com%{REQUEST_URI} [L,R=301,NE]

# --- Emergency booking-link trust leak fix ---
# --- Manual legacy exceptions (intentionally not in managed JSON) ---
# MANUAL_LEGACY_EXCEPTION: query-conditioned booking cleanup requires RewriteCond + QSD behavior.
# Tracked schedule booking URLs are intentionally collapsed to the clean booking page.
# This prevents SSI query-state errors from appearing before the booking CTA.
RewriteCond %{REQUEST_URI} ^/book-free-intro(?:\.html|/)?$ [NC]
RewriteCond %{QUERY_STRING} (^|&)(day=(monday|tuesday|wednesday|friday|saturday)|lane=mixed|source_page=schedule)(&|$) [NC]
RewriteRule ^book-free-intro(?:\.html|/)?$ https://senseisandy.com/book-free-intro [R=302,L,NE,QSD]

# BEGIN AUTO_LEGACY_REDIRECTS
