RewriteEngine On
RewriteBase /

# 1. Force HTTPS and Force non-www (senseisandy.com)
# This prevents duplicate content on www versions
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} ^www\. [NC]
RewriteRule ^ https://senseisandy.com%{REQUEST_URI} [L,R=301,NE]

# 2. Redirect /index.html (or /index) to Root (/)
# This prevents "senseisandy.com/index" from appearing
RewriteCond %{THE_REQUEST} \s/+(index\.html|index)[\s?] [NC]
RewriteRule ^ / [R=301,L]

# 3. Redirect external .html requests to Clean URLs (excluding index)
# Example: /schedule.html -> /schedule
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteCond %{REQUEST_URI} !/index\.html$ [NC]
RewriteRule ^ /%1 [R=301,L,NE]

# 4. Handle Specific Aliases & Misspellings
RewriteRule ^faq/?$ /faqs [L,R=301]
RewriteRule ^bios/?$ /bio [L,R=301]
RewriteRule ^class/?$ /classes [L,R=301]
RewriteRule ^curriculum/?$ /classes [L,R=301]
RewriteRule ^schedules/?$ /schedule [L,R=301]
RewriteRule ^press/?$ /openingpress [L,R=301]
RewriteRule ^presses/?$ /openingpress [L,R=301]
RewriteRule ^contacts/?$ /contact [L,R=301]
RewriteRule ^private-lessons/?$ /privates [L,R=301]

# 5. Magic Mapping (The "Engine")
# Internally serves .html files when clean URLs are requested
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L]