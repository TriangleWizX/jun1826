# END AUTO_LEGACY_REDIRECTS


# --- Legacy aliases (high-value + booking slugs) ---
# Hard-canonical high-value entry routes in one hop.
RewriteCond %{THE_REQUEST} \s/+contact\.html[\s?] [NC]
RewriteRule ^contact(?:\.html)?/?$ https://senseisandy.com/contact [L,R=301,NE,NC]
RewriteCond %{THE_REQUEST} \s/+book-free-intro(?:/index\.html|\.html)[\s?] [NC]
RewriteRule ^book-free-intro(?:/index\.html|\.html)$ https://senseisandy.com/book-free-intro [L,R=301,NE,NC]
RewriteRule ^book-free-intro/kids(?:/index\.html|/)?$ https://senseisandy.com/kids [L,R=301,NE,NC]
RewriteRule ^book-free-intro/teens(?:/index\.html|/)?$ https://senseisandy.com/teen-jiu-jitsu-tannersville-ny [L,R=301,NE,NC]
RewriteRule ^book-free-intro/adults(?:/index\.html|/)?$ https://senseisandy.com/adult-bjj [L,R=301,NE,NC]
RewriteRule ^adults(?:\.html)?/?$ https://senseisandy.com/adult-bjj [L,R=301,NE,NC]
RewriteRule ^options(?:\.html)?/?$ https://senseisandy.com/options-pricing [L,R=301,NE,NC]
RewriteRule ^tannersville-bjj-video-library(?:\.html)?/?$ https://senseisandy.com/bjj-videos [L,R=301,NE,NC]
RewriteRule ^partners-schools-parents(?:\.html)?/?$ https://senseisandy.com/school-families-jiu-jitsu [L,R=301,NE,NC]

# Serve calendar feed files directly and skip rewrite chains.
RewriteRule ^calendar/private-4pm\.ics$ /assets/calendar/private-lessons-4pm.ics [L,NC]
RewriteRule ^calendar/youth-5pm\.ics$ /assets/calendar/youth-class-5pm.ics [L,NC]
RewriteRule ^calendar/adult-6pm\.ics$ /assets/calendar/adult-class-6pm.ics [L,NC]
RewriteRule ^calendar/saturday\.ics$ /assets/calendar/saturday-block.ics [L,NC]
RewriteRule ^assets/calendar/(?:adults-lane|kids-lane|saturday-block|teens-lane)\.ics$ - [L,NC]

# Utility backend API routes.
RewriteRule ^api/?$ /api/index.php [L,QSA]
RewriteRule ^api/(.*)$ /api/index.php?path=$1 [L,QSA]

# Canonicalize legacy booking slugs that missed the lane slash.
RewriteRule ^book-free-introkids(?:\.html)?/?$ https://senseisandy.com/kids [L,R=301,NE,NC]
RewriteRule ^book-free-introteens(?:\.html)?/?$ https://senseisandy.com/teen-jiu-jitsu-tannersville-ny [L,R=301,NE,NC]
RewriteRule ^book-free-introadults(?:\.html)?/?$ https://senseisandy.com/adult-bjj [L,R=301,NE,NC]

# Tracked schedule booking URLs are intentionally collapsed to the clean booking page.
# This prevents SSI query-state errors from appearing before the booking CTA.

# Keyworded canonical hubs.
RewriteRule ^videos\.html/?$ https://senseisandy.com/bjj-videos [L,R=301,NE,NC]
RewriteRule ^bjj-faqs(?:\.html|/)$ https://senseisandy.com/bjj-faqs [L,R=301,NE,NC]
RewriteRule ^bjj-faqs$ /bjj-faqs.html [L]

# Convert legacy filter query variants into canonical hub URLs.
RewriteCond %{QUERY_STRING} (^|&)filter=kids(&|$) [NC]
RewriteRule ^videos/?$ https://senseisandy.com/videos/kids [L,R=301,NE,QSD]
RewriteCond %{QUERY_STRING} (^|&)filter=teens(&|$) [NC]
RewriteRule ^videos/?$ https://senseisandy.com/videos/teens [L,R=301,NE,QSD]
RewriteCond %{QUERY_STRING} (^|&)filter=adults(&|$) [NC]
RewriteRule ^videos/?$ https://senseisandy.com/videos/adults [L,R=301,NE,QSD]
RewriteCond %{QUERY_STRING} (^|&)filter=safety(&|$) [NC]
RewriteRule ^videos/?$ https://senseisandy.com/videos/self-defense [L,R=301,NE,QSD]
RewriteCond %{QUERY_STRING} (^|&)filter=technique(&|$) [NC]
RewriteRule ^videos/?$ https://senseisandy.com/videos/submissions [L,R=301,NE,QSD]
RewriteCond %{QUERY_STRING} (^|&)filter=vibes(&|$) [NC]
RewriteRule ^videos/?$ https://senseisandy.com/bjj-videos [L,R=301,NE,QSD]
RewriteCond %{QUERY_STRING} (^|&)filter=[^&]+(&|$) [NC]
RewriteRule ^videos/?$ https://senseisandy.com/bjj-videos [L,R=301,NE,QSD]
RewriteRule ^videos/?$ https://senseisandy.com/bjj-videos [L,R=301,NE]

# Canonicalize legacy video HTML URLs to clean URLs only for direct requests.
# Prevents redirect loops when /videos and /videos/<slug> are internally rewritten to .html files.
RewriteCond %{THE_REQUEST} \s/+videos/index\.html[\s?] [NC]
RewriteRule ^videos/index\.html$ https://senseisandy.com/bjj-videos [L,R=301,NE]
RewriteCond %{THE_REQUEST} \s/+videos/([a-z0-9-]+)\.html[\s?] [NC]
RewriteRule ^videos/([a-z0-9-]+)\.html$ https://senseisandy.com/videos/$1 [L,R=301,NE,NC]

# Resolve video clean URLs directly to generated HTML files.
# This serves both hub and watch routes from static .html outputs.
RewriteRule ^videos$ /videos/index.html [L]
RewriteRule ^videos/(kids|teens|adults|breakfalls|takedowns|guard-passing|escapes|submissions|self-defense)/?$ /videos/$1.html [L]
RewriteCond %{DOCUMENT_ROOT}/videos/$1.html -f
RewriteRule ^videos/([a-z0-9-]+)/?$ /videos/$1.html [L,NC]

# Canonicalize mixed-case video watch URLs to lowercase to avoid split signals.
# Uses Apache expression to compare original URI with lowercase URI.
RewriteCond expr "tolower(%{REQUEST_URI}) != %{REQUEST_URI}"
RewriteRule ^videos/(.+)$ https://senseisandy.com${tolower:%{REQUEST_URI}} [L,R=301,NE]

# Redirect legacy start URLs to the canonical booking page (all variants, incl. trailing slash).
RewriteCond %{REQUEST_URI} ^/(?:how-to-start|start-here)/index\.html?$ [NC]
RewriteCond %{IS_SUBREQ} !=true
RewriteRule ^ https://senseisandy.com/book-free-intro [L,R=301,NE]
RewriteCond %{REQUEST_URI} ^/(?:how-to-start|start-here)(?:\.html)?/?$ [NC]
RewriteCond %{IS_SUBREQ} !=true
RewriteRule ^ https://senseisandy.com/book-free-intro [L,R=301,NE]

# Redirect legacy slugs to new keyworded URLs (single hop, includes .html + trailing slash).
RewriteCond %{IS_SUBREQ} !=true
RewriteRule ^adult(?:\.html)?/?$ https://senseisandy.com/adult-bjj [L,R=301,NE]
RewriteCond %{IS_SUBREQ} !=true
RewriteRule ^classes(?:\.html)?/?$ https://senseisandy.com/programs [L,R=301,NE]
RewriteCond %{IS_SUBREQ} !=true
RewriteRule ^antibully(?:\.html)?/?$ https://senseisandy.com/bully-proof-jiu-jitsu-tannersville-ny [L,R=301,NE]
RewriteCond %{IS_SUBREQ} !=true
RewriteRule ^blackbelttrack(?:\.html)?/?$ https://senseisandy.com/black-belt-track [L,R=301,NE]
RewriteCond %{IS_SUBREQ} !=true
RewriteRule ^privates(?:\.html)?/?$ https://senseisandy.com/private-lessons [L,R=301,NE]
RewriteCond %{IS_SUBREQ} !=true
RewriteRule ^samuraibreak(?:\.html)?/?$ https://senseisandy.com/samurai-break [L,R=301,NE]
RewriteCond %{IS_SUBREQ} !=true
RewriteRule ^stretches(?:\.html)?/?$ https://senseisandy.com/bjj-stretches [L,R=301,NE]
RewriteCond %{IS_SUBREQ} !=true
RewriteRule ^blog/ginastica/index\.html?$ https://senseisandy.com/blog/bioginastica-movement-no-gi [L,R=301,NE]
RewriteCond %{IS_SUBREQ} !=true
RewriteRule ^blog/bio-ginastica/index\.html?$ https://senseisandy.com/blog/bioginastica-movement-no-gi [L,R=301,NE]
RewriteCond %{IS_SUBREQ} !=true
RewriteRule ^blog/onteora-park-summer-activities-tannersville-athletics/index\.html?$ https://senseisandy.com/blog/kinetic-chess-onteora-park [L,R=301,NE]
RewriteCond %{IS_SUBREQ} !=true
RewriteRule ^blog/onteora-park-summer-activities/index\.html?$ https://senseisandy.com/blog/kinetic-chess-onteora-park [L,R=301,NE]

# --- Near legacy aliases ---
# Consolidate scaled near-town pages into canonical hubs/pages.
RewriteCond %{IS_SUBREQ} !=true
RewriteRule ^near/?$ https://senseisandy.com/nearby-towns [L,R=301,NE]
RewriteCond %{IS_SUBREQ} !=true
RewriteRule ^cairo-ny-jiu-jitsu(?:/index\.html|/)?$ https://senseisandy.com/near/cairo-ny [L,R=301,NE]
RewriteCond %{IS_SUBREQ} !=true
RewriteRule ^catskill-ny-jiu-jitsu(?:/index\.html|/)?$ https://senseisandy.com/near/catskill-ny [L,R=301,NE]
RewriteCond %{IS_SUBREQ} !=true
RewriteRule ^hunter-ny-jiu-jitsu(?:/index\.html|/)?$ https://senseisandy.com/near/hunter-ny [L,R=301,NE]
RewriteCond %{IS_SUBREQ} !=true
RewriteRule ^near/tannersville-ny(?:/index\.html|/)?$ https://senseisandy.com/bjj-classes-tannersville-ny [L,R=301,NE]
RewriteCond %{IS_SUBREQ} !=true
RewriteRule ^near/hunter-mountain(?:/index\.html|/)?$ https://senseisandy.com/near/hunter-ny [L,R=301,NE]
RewriteCond %{IS_SUBREQ} !=true
RewriteRule ^near/windham-mountain(?:/index\.html|/)?$ https://senseisandy.com/near/windham-ny [L,R=301,NE]
RewriteCond %{IS_SUBREQ} !=true
RewriteRule ^near/esopus-creek-phoenicia(?:/index\.html|/)?$ https://senseisandy.com/near/phoenicia-ny [L,R=301,NE]
RewriteCond %{IS_SUBREQ} !=true
RewriteRule ^near/kaaterskill-falls(?:/index\.html|/)?$ https://senseisandy.com/near/palenville-ny [L,R=301,NE]
RewriteCond %{IS_SUBREQ} !=true
RewriteRule ^near/jewett-ny(?:/index\.html|/)?$ https://senseisandy.com/near/east-jewett-ny [L,R=301,NE]
RewriteCond %{IS_SUBREQ} !=true
RewriteRule ^near/jewett-east-jewett-ny(?:/index\.html|/)?$ https://senseisandy.com/near/east-jewett-ny [L,R=301,NE]
RewriteCond %{IS_SUBREQ} !=true
RewriteRule ^near/elka-park-ny(?:/index\.html|/)?$ https://senseisandy.com/near/east-jewett-ny [L,R=301,NE]
RewriteCond %{IS_SUBREQ} !=true
RewriteRule ^near/onteora-park-ny(?:/index\.html|/)?$ https://senseisandy.com/near/east-jewett-ny [L,R=301,NE]
RewriteCond %{IS_SUBREQ} !=true
RewriteRule ^near/lanesville-ny(?:/index\.html|/)?$ https://senseisandy.com/near/phoenicia-ny [L,R=301,NE]
RewriteCond %{IS_SUBREQ} !=true
RewriteRule ^near/lexington-ny(?:/index\.html|/)?$ https://senseisandy.com/near/windham-ny [L,R=301,NE]
RewriteCond %{IS_SUBREQ} !=true
RewriteRule ^near/saugerties-ny(?:/index\.html|/)?$ https://senseisandy.com/near/woodstock-ny [L,R=301,NE]
RewriteCond %{IS_SUBREQ} !=true
RewriteRule ^checkout(?:\.html)?/?$ https://senseisandy.com/adult-bjj [L,R=301,NE]


# --- Static assets / security headers / caching ---
# Backward compatibility for legacy fingerprinted image URLs (e.g. name.abc123.webp).
# If the unhashed file exists, internally serve it instead of returning 404.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{DOCUMENT_ROOT}/assets/images/$1.$2 -f
RewriteRule ^assets/images/(.+)\.[0-9a-f]{6}\.(png|jpe?g|webp|gif|svg|avif)$ /assets/images/$1.$2 [L,NC]

# Normalize /home to the canonical root in one hop.
RewriteRule ^home/?$ / [R=301,L,NE]

# Add explicit noindex headers for template/redirect pages.
SetEnvIf Request_URI "^/near/template(?:\.html)?$" NOINDEX=1
SetEnvIf Request_URI "^/curriculum(?:/index\.html|/)?$" NOINDEX=1
SetEnvIfNoCase Request_URI "^/checkout(?:/|\.html)?$" NOINDEX_TXN=1
SetEnvIfNoCase Request_URI "^/waiver(?:\.html)?/?$" FORCE_INDEX=1
SetEnvIfNoCase Request_URI "^/blog/confidence-protocol(?:/index\.html|/)?$" FORCE_INDEX=1
<IfModule mod_headers.c>
  Header set X-Robots-Tag "noindex, nofollow" env=NOINDEX
  Header always set X-Robots-Tag "noindex, nofollow, noarchive" env=NOINDEX_TXN
  Header always unset X-Robots-Tag env=FORCE_INDEX
  Header always set X-Robots-Tag "index, follow" env=FORCE_INDEX
</IfModule>

<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Report-To "{\"group\":\"csp-endpoint\",\"max_age\":10886400,\"endpoints\":[{\"url\":\"https://senseisandy.com/api/csp-reports\"}]}"
  Header always set Reporting-Endpoints "csp-endpoint=\"https://senseisandy.com/api/csp-reports\""
  Header always set Content-Security-Policy-Report-Only "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; form-action 'self' https://formspree.io; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://cdn.jsdelivr.net https://assets.calendly.com https://embed.tawk.to https://*.tawk.to; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://assets.calendly.com https://fonts.googleapis.com; img-src 'self' data: blob: https://www.googletagmanager.com https://www.google-analytics.com https://*.ytimg.com https://i.ytimg.com https://tawk.link https://*.tawk.to; font-src 'self' data: https://fonts.gstatic.com https://cdn.jsdelivr.net; connect-src 'self' https://www.googletagmanager.com https://www.google-analytics.com https://region1.google-analytics.com https://stats.g.doubleclick.net https://assets.calendly.com https://calendly.com https://formspree.io https://embed.tawk.to https://va.tawk.to https://*.tawk.to wss://*.tawk.to; frame-src https://assets.calendly.com https://calendly.com https://www.youtube.com https://www.youtube-nocookie.com https://maps.google.com https://embed.tawk.to https://*.tawk.to; manifest-src 'self'; media-src 'self' blob:; worker-src 'self' blob:; upgrade-insecure-requests; report-uri /api/csp-reports; report-to csp-endpoint"
  Header always set Vary "Accept-Encoding"
</IfModule>

<IfModule mod_headers.c>
  # Long cache for fingerprinted static assets.
  <FilesMatch "\\.[0-9a-f]{6}\\.(?:css|js|png|jpe?g|gif|webp|svg|avif|ico|woff2?|ttf|mp4|webm)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Short cache for HTML (edge-friendly).
  <FilesMatch "\\.(?:html)$">
    Header set Cache-Control "public, max-age=300, s-maxage=300"
  </FilesMatch>

  # Default cache for non-fingerprinted static assets.
  <FilesMatch "\\.(?:css|js|png|jpe?g|gif|webp|svg|avif|ico|woff2?|ttf|mp4|webm)$">
    Header set Cache-Control "public, max-age=2592000, stale-while-revalidate=86400"
  </FilesMatch>
</IfModule>

<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/css application/javascript application/json image/svg+xml text/plain text/xml application/xml
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml text/plain text/xml application/xml
</IfModule>

<IfModule mod_headers.c>
  Header merge Vary "Accept"
</IfModule>

FileETag MTime Size

<IfModule mod_mime.c>
  AddType text/calendar .ics
</IfModule>

# Block access to editor/git artifacts (security + avoids accidental indexing)
RewriteCond %{REQUEST_URI} !^/\.well-known(?:/|$) [NC]
RewriteRule (^|/)\. - [F]

# Serve minified site CSS (keeps HTML unchanged)
RewriteRule ^assets/css/styles\.css$ /assets/css/styles.min.css [L]

# Allow SSI fragments (nav/footer) to render inside .html pages
Options +IncludesNOEXEC
SSIErrorMsg ""
DirectoryIndex index.html
AddType text/html .html
AddOutputFilter INCLUDES .html

# Redirect legacy curriculum URLs in one hop
RewriteCond %{IS_SUBREQ} !=true
RewriteRule ^curriculum(?:\.html)?/?$ https://senseisandy.com/programs [L,R=301,NE]

# 1. Collapse index hits to the canonical directory/root in a single hop
RewriteCond %{THE_REQUEST} \s+/index(?:\.html?)?[\s?] [NC]
RewriteCond %{IS_SUBREQ} !=true
RewriteRule ^index(?:\.html?)?$ https://senseisandy.com/ [L,R=301,NE]
RewriteCond %{THE_REQUEST} \s/+(.+?)/index(?:\.html?)?[\s?] [NC]
RewriteCond %{IS_SUBREQ} !=true
RewriteRule ^ https://senseisandy.com/%1 [L,R=301,NE]

# 1b. Fix old press URL in one hop (was moved into /archive/)
RewriteCond %{IS_SUBREQ} !=true
RewriteRule ^openingpress(?:\.html)?/?$ https://senseisandy.com/archive/openingpress [L,R=301,NE]

# 1c. Catch known aliases with optional .html in one hop to final canonical targets.
RewriteCond %{IS_SUBREQ} !=true
RewriteRule ^mountain-pass(?:\.html)?/?$ https://senseisandy.com/book-free-intro [L,R=301,NE]
RewriteCond %{IS_SUBREQ} !=true
RewriteRule ^bio(?:\.html|/)$ https://senseisandy.com/bio [L,R=301,NE,NC]

# 2. Redirect explicit .html requests (except index) to clean URLs on the canonical host
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteCond %{REQUEST_URI} !^/index\.html?$ [NC]
RewriteCond %{REQUEST_URI} !^/(?:nav-include|footer-include|cta-hero|cta-decision|cta-footer|cta-header|offer-block|schedule-block|pricing-module-fragment|safety-promise|_includes/[^/]+|partials/[^/]+)\.html$ [NC]
RewriteCond %{IS_SUBREQ} !=true
RewriteRule ^ https://senseisandy.com/%1 [L,R=301,NE]

# 3. Handle specific aliases & misspellings in one hop to the canonical URL
RewriteCond %{REQUEST_URI} ^/blog/gi-vs-no-gi-bjj-cheat-code/$ [NC]
RewriteRule ^blog/gi-vs-no-gi-bjj-cheat-code/$ https://senseisandy.com/blog/gi-vs-no-gi-bjj-cheat-code [L,R=301,NE,QSA]

# --- Trailing slash / index / .html normalization ---
# 4a. Remove trailing slash for all non-root URLs (canonical: no trailing slash).
RewriteCond %{REQUEST_URI} !^/book-free-intro/$ [NC,OR]
RewriteCond %{QUERY_STRING} !(^|&)src=[^&]+(&|$) [NC]
RewriteCond %{REQUEST_URI} !^/$
RewriteCond %{REQUEST_URI} ^/(.+)/$
RewriteCond %{IS_SUBREQ} !=true
RewriteRule ^ https://senseisandy.com/%1 [L,R=301,NE]

# 4b. Serve directory index when requesting a directory without a trailing slash.
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_URI} !/$
RewriteCond %{IS_SUBREQ} !=true
RewriteRule ^(.+)$ $1/index.html [L]

# 4c. Harden explicit clean route for top-level hunter comparison page.
# This avoids edge-case misses when generic .html fallback is bypassed upstream.
RewriteRule ^martial-arts-hunter-ny/?$ /martial-arts-hunter-ny.html [L]
RewriteRule ^teen-jiu-jitsu-tannersville-ny/?$ /teen-jiu-jitsu-tannersville-ny.html [L]
RewriteRule ^jiu-jitsu-safety-tannersville-ny/?$ /jiu-jitsu-safety-tannersville-ny.html [L]

# 5. Internally serve .html files when clean URLs are requested
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L]
