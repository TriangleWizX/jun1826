APP_ENV=production
APP_URL=https://senseisandy.com
DB_PATH=/home/twizss/Documents/ssbjjweb/tmb/data/senseisandy.sqlite
IP_HASH_SALT=replace-with-long-random-secret

# Comma-separated allowlist for browser calls to /api/*
ALLOWED_ORIGINS=https://senseisandy.com,https://www.senseisandy.com

# Shared secret required by POST /api/webhook/booking
BOOKING_WEBHOOK_SECRET=replace-with-booking-webhook-secret

# Shared secret required by owner-only ops endpoints:
# /api/students, /api/sessions, /api/attendance, /api/waivers, /api/exports/attendance.csv
OPS_API_KEY=replace-with-ops-api-key

# Optional review refresh source (used by jobs/refresh_reviews.php)
REVIEWS_SOURCE_URL=
REVIEWS_PROVIDER=google
