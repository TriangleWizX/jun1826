<body class="lane-mixed page-home ss-page ss-page-home ss-has-community-bg ss-has-hub-preview page-home-mobile-layer">

  <!--#include virtual="/nav-include.html" -->

  <div id="scrollProgress"></div>

  <main class="ss-main ss-home-mockup" id="main-content" role="main">
    <section class="ss-home-hero ss-section ss-reveal" aria-labelledby="ss-home-hero-title">
      <div class="container">
        <div class="ss-home-hero__grid">
          <div class="ss-home-hero__copy ss-reveal delay-1">
            <span class="ss-eyebrow-badge">Catskills Brazilian Jiu-Jitsu</span>
            <h1 id="ss-home-hero-title">Build Confidence, Strength, and Skill Through Jiu-Jitsu</h1>
            <p class="ss-home-lede">
              Beginner-friendly Brazilian Jiu-Jitsu for kids, parents, and adults in Tannersville, New York.
            </p>
            <p class="ss-home-note">
              Train in a welcoming small-group setting with clear coaching, controlled partner practice, and a step-by-step path forward.
            </p>

            <div class="ss-home-actions" aria-label="Primary actions">
              <a class="ss-btn ss-btn-primary ss-btn-island group" href="/book-free-intro" data-cta-target="intro"
                data-cta-label="Reserve Your Free Intro" data-cta-src="home-hero"
                data-cta-placement="funnel_book" data-cta-tier="primary" data-cta-lane="mixed">
                <span class="ss-btn-text">Reserve Your Free Intro</span>
                <span class="ss-btn-icon-wrapper">
                  <i class="bi bi-calendar2-event" aria-hidden="true"></i>
                </span>
              </a>
              <a class="ss-btn ss-btn-light ss-btn-island group" href="#choose-starting-point" data-cta-target="scroll"
                data-cta-src="home-hero" data-cta-placement="hero_scroll" data-cta-tier="secondary" data-cta-lane="mixed">
                <span class="ss-btn-text">Find Your Class</span>
                <span class="ss-btn-icon-wrapper">
                  <i class="bi bi-arrow-down" aria-hidden="true"></i>
                </span>
              </a>
              <a class="ss-home-inline-link ss-home-inline-link--trust" href="sms:+19177368649" data-cta-target="text"
                data-cta-src="home-hero" data-cta-placement="hero_text" data-cta-tier="tertiary" data-cta-lane="mixed">
                Nervous or unsure? Text Sandy First
              </a>
            </div>

            <div class="ss-home-pills" aria-label="First visit proof">
              <span><i class="bi bi-people" aria-hidden="true"></i> Small classes</span>
              <span><i class="bi bi-person-check" aria-hidden="true"></i> Guided first visits</span>
              <span><i class="bi bi-eye" aria-hidden="true"></i> Parents welcome to watch</span>
              <span><i class="bi bi-clock" aria-hidden="true"></i> Morning and evening options</span>
            </div>
          </div>

          <div class="ss-home-hero__media ss-reveal delay-2">
            <div class="ss-double-bezel">
              <div class="ss-double-bezel-inner">
                <figure class="ss-home-media-frame mb-0">
                  <img src="/assets/images/IMG_20260415_172726_009.f9acc0.webp" alt="Sensei Sandy BJJ room with students training in a calm, beginner-friendly class"
                    width="1600" height="900" fetchpriority="high" decoding="async" loading="eager">
                  <figcaption class="ss-home-media-badge">
                    <img src="/assets/img/brand/sensei-sandy-bjj-logo-256.905957.webp" alt="" width="32" height="32" decoding="async">
                    <span>CALM ROOM<br>STRONG PEOPLE<br>BETTER EVERY DAY</span>
                  </figcaption>
                </figure>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="ss-home-section ss-home-section--lane-schedule" id="choose-starting-point" aria-labelledby="ss-home-lane-title">
      <div class="container">
        <div class="ss-home-panel">
          <div class="ss-home-lanes-panel ss-reveal">
            <span class="ss-home-kicker">Choose Your Starting Point</span>
            <div class="ss-home-section-head">
              <h2 id="ss-home-lane-title">Choose Your Starting Point</h2>
              <p>
                We organize our training into three clear paths based on your goals.
              </p>
            </div>

            <div class="ss-home-lane-grid">
              <a class="ss-home-lane-bento-card ss-home-lane-bento-card--kids ss-reveal delay-1" href="/kids" data-cta-target="kids"
                data-cta-src="home-lanes" data-cta-placement="lane_card" data-cta-tier="secondary" data-cta-lane="kids">
                <div class="ss-double-bezel">
                  <div class="ss-double-bezel-inner">
                    <div>
                      <div class="ss-lane-bento-header">
                        <span class="ss-lane-bento-badge">Kids &amp; Families</span>
                        <span class="ss-lane-bento-arrow" aria-hidden="true"><i class="bi bi-arrow-up-right"></i></span>
                      </div>
                      <div class="ss-lane-bento-body">
                        <h3>Kids Jiu-Jitsu</h3>
                        <p>Help your child build confidence, focus, coordination, and positive training habits through structured Brazilian Jiu-Jitsu. Parents are welcome to watch and meet the instructor.</p>
                      </div>
                    </div>
                    <div class="ss-lane-bento-footer">
                      <i class="bi bi-arrow-right"></i>
                      <span>Explore Kids Classes</span>
                    </div>
                  </div>
                </div>
              </a>

              <a class="ss-home-lane-bento-card ss-home-lane-bento-card--adult-beginners ss-reveal delay-2" href="/adult-bjj" data-cta-target="adults"
                data-cta-src="home-lanes" data-cta-placement="lane_card" data-cta-tier="secondary" data-cta-lane="adults">
                <div class="ss-double-bezel">
                  <div class="ss-double-bezel-inner">
                    <div>
                      <div class="ss-lane-bento-header">
                        <span class="ss-lane-bento-badge">First-Time Adults</span>
                        <span class="ss-lane-bento-arrow" aria-hidden="true"><i class="bi bi-arrow-up-right"></i></span>
                      </div>
                      <div class="ss-lane-bento-body">
                        <h3>Adult Beginners</h3>
                        <p>Start with clear instruction, supportive partners, and practical skills that develop naturally from class to class. Perfect for first-time students and returning martial artists.</p>
                      </div>
                    </div>
                    <div class="ss-lane-bento-footer">
                      <i class="bi bi-arrow-right"></i>
                      <span>Explore Adult Classes</span>
                    </div>
                  </div>
                </div>
              </a>

              <a class="ss-home-lane-bento-card ss-home-lane-bento-card--active-adults ss-reveal delay-3" href="/schedule" data-cta-target="schedule"
                data-cta-src="home-lanes" data-cta-placement="lane_card" data-cta-tier="secondary" data-cta-lane="mixed">
                <div class="ss-double-bezel">
                  <div class="ss-double-bezel-inner">
                    <div>
                      <div class="ss-lane-bento-header">
                        <span class="ss-lane-bento-badge">Active Catskills Adults</span>
                        <span class="ss-lane-bento-arrow" aria-hidden="true"><i class="bi bi-arrow-up-right"></i></span>
                      </div>
                      <div class="ss-lane-bento-body">
                        <h3>Active Adults</h3>
                        <p>Build strength, mobility, conditioning, and technical skill through engaging full-body training. The room is organized around confidence, skill, fitness, and community.</p>
                      </div>
                    </div>
                    <div class="ss-lane-bento-footer">
                      <i class="bi bi-arrow-right"></i>
                      <span>View the Weekly Schedule</span>
                    </div>
                  </div>
                </div>
              </a>
            </div>
          </div>

          <aside class="ss-home-schedule-card ss-reveal delay-1" aria-labelledby="ss-home-schedule-title">
            <div class="ss-double-bezel">
              <div class="ss-double-bezel-inner">
                <div class="ss-home-section-head ss-home-section-head--schedule">
                  <div>
                    <span class="ss-home-kicker">This Week at Sensei Sandy BJJ</span>
                    <h2 id="ss-home-schedule-title">Weekly schedule at a glance.</h2>
                  </div>
                  <a class="ss-home-inline-link" href="/schedule" data-cta-target="schedule"
                    data-cta-src="home-schedule" data-cta-placement="schedule_preview" data-cta-tier="secondary"
                    data-cta-lane="mixed">
                    View Full Schedule <i class="bi bi-arrow-right" aria-hidden="true"></i>
                  </a>
                </div>

                <div class="ss-home-schedule-table" role="table" aria-label="Weekly jiu-jitsu class schedule preview">
                  <div class="ss-home-schedule-row" role="row">
                    <div class="ss-home-schedule-day" role="rowheader">MON</div>
                    <div class="ss-home-schedule-slots" role="cell">
                      <span class="ss-home-slot"><strong>5:00 PM</strong> Youth</span>
                      <span class="ss-home-slot"><strong>6:00 PM</strong> Adults</span>
                    </div>
                  </div>
                  <div class="ss-home-schedule-row" role="row">
                    <div class="ss-home-schedule-day" role="rowheader">TUE</div>
                    <div class="ss-home-schedule-slots" role="cell">
                      <span class="ss-home-slot"><strong>6:30 AM</strong> Before Work BJJ</span>
                      <span class="ss-home-slot"><strong>5:00 PM</strong> Youth</span>
                      <span class="ss-home-slot"><strong>6:00 PM</strong> Adults</span>
                    </div>
                  </div>
                  <div class="ss-home-schedule-row" role="row">
                    <div class="ss-home-schedule-day" role="rowheader">WED</div>
                    <div class="ss-home-schedule-slots" role="cell">
                      <span class="ss-home-slot"><strong>10:00 AM</strong> Morning BJJ</span>
                      <span class="ss-home-slot ss-home-slot--nogi"><strong>5:00 PM</strong> Youth No-Gi</span>
                      <span class="ss-home-slot ss-home-slot--nogi"><strong>6:00 PM</strong> Adult No-Gi</span>
                    </div>
                  </div>
                  <div class="ss-home-schedule-row" role="row">
                    <div class="ss-home-schedule-day" role="rowheader">THU</div>
                    <div class="ss-home-schedule-slots" role="cell">
                      <span class="ss-home-slot"><strong>6:30 AM</strong> Before Work BJJ</span>
                    </div>
                  </div>
                  <div class="ss-home-schedule-row" role="row">
                    <div class="ss-home-schedule-day" role="rowheader">FRI</div>
                    <div class="ss-home-schedule-slots" role="cell">
                      <span class="ss-home-slot"><strong>10:00 AM</strong> Morning BJJ</span>
                      <span class="ss-home-slot"><strong>5:00 PM</strong> Youth</span>
                      <span class="ss-home-slot"><strong>6:00 PM</strong> Adults</span>
                    </div>
                  </div>
                  <div class="ss-home-schedule-row" role="row">
                    <div class="ss-home-schedule-day" role="rowheader">SAT</div>
                    <div class="ss-home-schedule-slots" role="cell">
                      <span class="ss-home-slot ss-home-slot--nogi"><strong>10:30 AM</strong> Adult No-Gi</span>
                    </div>
                  </div>
                  <div class="ss-home-schedule-row" role="row">
                    <div class="ss-home-schedule-day" role="rowheader">SUN</div>
                    <div class="ss-home-schedule-slots" role="cell">
