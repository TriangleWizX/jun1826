  <script>
    (function mobileAccordionGroups() {
      const isMobile = window.matchMedia('(max-width: 767.98px)');
      const groups = document.querySelectorAll('[data-accordion-group]');
      if (!groups.length) return;

      groups.forEach((group) => {
        group.addEventListener('toggle', (event) => {
          const detail = event.target;
          if (!detail || detail.tagName !== 'DETAILS' || !detail.open || !isMobile.matches) return;
          group.querySelectorAll('details[open]').forEach((peer) => {
            if (peer !== detail) peer.open = false;
          });
        }, true);
      });
    })();
  </script>

  <script>
    (function deferHomepageAnalytics() {
      let loaded = false;

      const scheduleIdle = (fn) => {
        if ('requestIdleCallback' in window) {
          window.requestIdleCallback(fn, { timeout: 3000 });
          return;
        }
        window.setTimeout(fn, 1400);
      };

      const loadScript = (src, attrs = {}) => new Promise((resolve, reject) => {
        if (document.querySelector(`script[src="${src}"]`)) {
          resolve();
          return;
        }
        const script = document.createElement('script');
        script.src = src;
        script.async = true;
        Object.entries(attrs).forEach(([key, value]) => {
          script.setAttribute(key, value);
        });
        script.onload = () => resolve();
        script.onerror = reject;
        document.head.appendChild(script);
      });

      const loadAnalytics = () => {
        if (loaded) return;
        loaded = true;

        window.dataLayer = window.dataLayer || [];
        window.gtag = window.gtag || function gtag() { window.dataLayer.push(arguments); };
        window.gtag('js', new Date());
        window.gtag('config', 'G-03GTSG5ECF');

        loadScript('https://www.googletagmanager.com/gtag/js?id=G-03GTSG5ECF').catch(() => { });
        loadScript('https://analytics.ahrefs.com/analytics.js', { 'data-key': '7wa4kb0Phyu0r+dNkM/tTQ' }).catch(() => { });
      };

      const onFirstIntent = () => {
        scheduleIdle(loadAnalytics);
        window.removeEventListener('pointerdown', onFirstIntent, true);
        window.removeEventListener('keydown', onFirstIntent, true);
        window.removeEventListener('touchstart', onFirstIntent, true);
        window.removeEventListener('mouseover', onFirstIntent, true);
      };

      window.addEventListener('pointerdown', onFirstIntent, { once: true, capture: true, passive: true });
      window.addEventListener('keydown', onFirstIntent, { once: true, capture: true });
      window.addEventListener('touchstart', onFirstIntent, { once: true, capture: true, passive: true });
      window.addEventListener('mouseover', onFirstIntent, { once: true, capture: true, passive: true });

      if (document.readyState === 'complete') {
        scheduleIdle(loadAnalytics);
      } else {
        window.addEventListener('load', () => scheduleIdle(loadAnalytics), { once: true });
      }
    })();
  </script>

  <script>
    (function () {
      const wrappers = document.querySelectorAll('[data-ig-lazy]');
      if (!wrappers.length) return;

      const mobileQuery = window.matchMedia('(max-width: 767.98px)');
      const isMobile = mobileQuery.matches;
      let embedScriptPromise = null;

      const loadInstagramScript = () => {
        if (window.instgrm && window.instgrm.Embeds) {
          return Promise.resolve(window.instgrm);
        }
        if (embedScriptPromise) return embedScriptPromise;
        const existing = document.querySelector('script[data-instgrm-embed-loader]');
        if (existing) {
          embedScriptPromise = new Promise((resolve, reject) => {
            existing.addEventListener('load', () => resolve(window.instgrm), { once: true });
            existing.addEventListener('error', reject, { once: true });
          });
          return embedScriptPromise;
        }
        embedScriptPromise = new Promise((resolve, reject) => {
          const script = document.createElement('script');
          script.async = true;
          script.src = 'https://www.instagram.com/embed.js';
          script.dataset.instgrmEmbedLoader = 'true';
          script.onload = () => resolve(window.instgrm);
          script.onerror = reject;
          document.body.appendChild(script);
        });
        return embedScriptPromise;
      };

      const processEmbeds = () => {
        if (!window.instgrm || !window.instgrm.Embeds || typeof window.instgrm.Embeds.process !== 'function') {
          return;
        }
        window.instgrm.Embeds.process();
      };

      wrappers.forEach((wrapper) => {
        const poster = wrapper.querySelector('[data-ig-poster]');
        const embed = wrapper.querySelector('[data-ig-target]');
        if (!embed) return;

        const setFailedState = () => {
          wrapper.classList.add('is-ig-error');
          if (poster) poster.hidden = true;
          embed.hidden = true;
        };

        if (!isMobile) {
          wrapper.classList.add('is-ig-loaded');
          embed.hidden = false;
          if (poster) poster.hidden = true;
          loadInstagramScript().then(processEmbeds).catch(setFailedState);
          return;
        }

        wrapper.classList.add('is-ig-mobile-lazy');
        embed.hidden = true;

        if (!poster) return;
        poster.addEventListener('click', () => {
          if (wrapper.classList.contains('is-ig-loading') || wrapper.classList.contains('is-ig-loaded')) return;
          wrapper.classList.add('is-ig-loading');
          loadInstagramScript()
            .then(() => {
              wrapper.classList.remove('is-ig-loading');
              wrapper.classList.add('is-ig-loaded');
              poster.hidden = true;
              embed.hidden = false;
              processEmbeds();
            })
            .catch(() => {
              wrapper.classList.remove('is-ig-loading');
              setFailedState();
            });
        }, { passive: true });
      });
    })();
  </script>

  <script>
    (function () {
      const trigger = document.querySelector('[data-hero-image-toggle]');
      if (!trigger) return;
      const image = trigger.querySelector('img');
      if (!image) return;
      image.setAttribute('draggable', 'false');

      const MIN_ZOOM = 1;
      const MAX_ZOOM = 4;
      let zoom = 1;
      let panX = 0;
      let panY = 0;
      let isPanning = false;
      let suppressClickClose = false;
      let lastClientX = 0;
      let lastClientY = 0;
      let activePointerId = null;
      let isMousePanning = false;

      const applyTransform = () => {
        image.style.transformOrigin = 'center center';
        image.style.transform = `translate(${panX}px, ${panY}px) scale(${zoom})`;
        image.style.cursor = zoom > 1 ? (isPanning ? 'grabbing' : 'grab') : 'zoom-out';
      };

      const resetTransform = () => {
        zoom = 1;
        panX = 0;
        panY = 0;
        isPanning = false;
        suppressClickClose = false;
        applyTransform();
      };

      const closeIfOpen = () => {
        if (!document.body.classList.contains('heroCore-image-open')) return;
        document.body.classList.remove('heroCore-image-open');
        trigger.setAttribute('aria-label', 'Toggle full viewport image');
        resetTransform();
      };

      trigger.addEventListener('click', () => {
        const isOpenNow = document.body.classList.contains('heroCore-image-open');

        if (!isOpenNow) {
          document.body.classList.add('heroCore-image-open');
          resetTransform();
          trigger.setAttribute('aria-label', 'Close full viewport image');
          return;
        }

        if (suppressClickClose) {
          suppressClickClose = false;
          return;
        }

        const isOpen = document.body.classList.toggle('heroCore-image-open');
        trigger.setAttribute('aria-label', isOpen ? 'Close full viewport image' : 'Toggle full viewport image');
        if (!isOpen) resetTransform();
      });

      trigger.addEventListener('wheel', (event) => {
        if (!document.body.classList.contains('heroCore-image-open')) return;

        event.preventDefault();
        const delta = -event.deltaY;
        const factor = Math.exp(delta * 0.0015);
        const nextZoom = Math.min(MAX_ZOOM, Math.max(MIN_ZOOM, zoom * factor));
        if (nextZoom === zoom) return;

        zoom = nextZoom;
        if (zoom <= 1) {
          panX = 0;
          panY = 0;
        }
        suppressClickClose = true;
        applyTransform();
      }, { passive: false });

      trigger.addEventListener('dragstart', (event) => {
        event.preventDefault();
      });

      trigger.addEventListener('pointerdown', (event) => {
        if (!document.body.classList.contains('heroCore-image-open')) return;
        if (event.pointerType === 'mouse') return;
        if (event.button !== 0) return;

        isPanning = true;
        activePointerId = event.pointerId;
        lastClientX = event.clientX;
        lastClientY = event.clientY;
        suppressClickClose = true;
        if (typeof trigger.setPointerCapture === 'function') {
          trigger.setPointerCapture(event.pointerId);
        }
        applyTransform();
        event.preventDefault();
      });

      window.addEventListener('pointermove', (event) => {
        if (!isPanning || event.pointerId !== activePointerId) return;
        panX += event.clientX - lastClientX;
        panY += event.clientY - lastClientY;
        lastClientX = event.clientX;
        lastClientY = event.clientY;
        applyTransform();
      });

      const stopPanning = (event) => {
        if (!isPanning) return;
        if (event && activePointerId !== null && event.pointerId !== activePointerId) return;
        isPanning = false;
        if (event && typeof trigger.releasePointerCapture === 'function') {
          try { trigger.releasePointerCapture(event.pointerId); } catch (_) { }
        }
        activePointerId = null;
        applyTransform();
      };

      window.addEventListener('pointerup', stopPanning);
      window.addEventListener('pointercancel', stopPanning);

      trigger.addEventListener('mousedown', (event) => {
        if (!document.body.classList.contains('heroCore-image-open')) return;
        if (event.button !== 0) return;

        isMousePanning = true;
        suppressClickClose = true;
        lastClientX = event.clientX;
        lastClientY = event.clientY;
        image.style.cursor = 'grabbing';
        event.preventDefault();
      });

      window.addEventListener('mousemove', (event) => {
        if (!isMousePanning) return;
        panX += event.clientX - lastClientX;
        panY += event.clientY - lastClientY;
        lastClientX = event.clientX;
        lastClientY = event.clientY;
        applyTransform();
      });

      window.addEventListener('mouseup', () => {
        if (!isMousePanning) return;
        isMousePanning = false;
        applyTransform();
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') closeIfOpen();
      });
    })();
  </script>

  <script src="/js/voice-faq-accordion.2b6c27.js"></script>

  <script src="/assets/js/ss-evidence-registry.01466d.js" defer></script>
  <script src="/assets/js/ss-evidence-accordion.c9619a.js" defer></script>
  <script>
    (function() {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('ss-reveal-active');
            observer.unobserve(entry.target);
          }
        });
      }, {
        threshold: 0.15,
        rootMargin: '0px 0px -50px 0px'
      });
      document.querySelectorAll('.ss-reveal').forEach(el => observer.observe(el));
    })();
  </script>
